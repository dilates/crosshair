{
  "name": "dilates-crosshair",
  "productName": "Dilates Crosshair",
  "version": "1.1.1",
  "description": "Free, open-source crosshair overlay for Linux gaming — a Crosshair X alternative",
  "desktopName": "io.github.dilates.crosshair",
  "main": "dist/main.js",
  "author": "dilates",
  "homepage": "https://github.com/dilates/crosshair",
  "repository": {
    "type": "git",
    "url": "https://github.com/dilates/crosshair.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "appimage": "npm run build && electron-builder --linux AppImage",
    "flatpak": "npm run build && electron-builder --linux flatpak"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "@types/node": "^20.10.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {},
  "build": {
    "appId": "io.github.dilates.crosshair",
    "productName": "Dilates Crosshair",
    "files": ["dist", "public", "package.json"],
    "linux": {
      "target": ["AppImage", "flatpak"],
      "category": "Utility",
      "icon": "assets/icon.png"
    },
    "appImage": {
      "category": "Utility",
      "synopsis": "Custom crosshair overlay for gaming"
    },
    "flatpak": {
      "finishArgs": [
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--share=network"
      ]
    }
  }
}
